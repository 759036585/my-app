PORT=3001
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/my-app
JWT_SECRET=your-super-secret-jwt-key-change-in-production
FRONTEND_URL=http://localhost:5173

# ── 百度千帆大模型 API 配置 ──
# 从百度智能云控制台获取 API Key: https://console.bce.baidu.com/qianfan/ais/console/onlineService
QIANFAN_API_KEY=your-qianfan-api-key-here
# 可选：自定义API地址（默认: https://qianfan.baidubce.com）
# QIANFAN_BASE_URL=https://qianfan.baidubce.com
# 可选：默认模型（默认: ernie-4.0-8k）
# QIANFAN_MODEL=ernie-4.0-8k
